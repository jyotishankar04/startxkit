{
  "name": "@startxkit/core",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "tsdown": "^0.12.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
