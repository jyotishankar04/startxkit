{{#if hasEnv}}import "dotenv/config";
{{/if}}import { serve } from "@hono/node-server";
import { Hono } from "hono";
import { healthRoutes } from "./modules/health/health.route";
{{#if isPino}}import pino from "pino";
{{/if}}

const app = new Hono();
const port = Number(process.env.PORT ?? 4000);
{{#if isPino}}const logger = pino();
{{/if}}

app.route("{{apiPrefix}}/health", healthRoutes);

serve({ fetch: app.fetch, port }, () => {
  {{#if isPino}}logger.info(`Server running on http://localhost:${port}`);{{else}}{{#if hasLogger}}console.log(`Server running on http://localhost:${port}`);{{/if}}{{/if}}
});
